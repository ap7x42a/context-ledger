{
  "note": "Use scripts/install_hooks.py instead of copying this path-specific example.",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "__PYTHON__ __SKILL_ROOT__/hooks/runtime_hook.py --runtime claude-code --project-root __PROJECT_ROOT__ --context-ledger-hook-v2",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
